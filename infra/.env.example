# ──────────────────────────────────────────────────────────────
# 로컬 개발 환경 변수 템플릿
# 사용법: cp .env.example .env 후 .env 파일에서 값 수정
# .env 파일은 .gitignore에 포함되어 있으므로 Git에 커밋되지 않음
# ──────────────────────────────────────────────────────────────

# ── Kafka ──────────────────────────────────────────────────────
# KRaft 클러스터 고유 ID (base64 URL-safe 인코딩된 UUID)
# 변경 시 kafka-data 볼륨을 삭제 후 재시작 필요: docker volume rm infra_kafka-data
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_EXTERNAL_PORT=9092

# ── Schema Registry ────────────────────────────────────────────
# 호스트(로컬 앱)에서 Schema Registry에 접속할 때 사용하는 포트 매핑 값
SCHEMA_REGISTRY_PORT=8085
# Debezium Connector 런타임(컨테이너 내부 네트워크)에서 접근할 Registry URL
# register-connectors.sh 가 value.converter.schema.registry.url 로 주입
SCHEMA_REGISTRY_URL=http://schema-registry:8081
# 호스트에서 register-schemas.sh 실행 시 사용할 Registry URL (선택)
SCHEMA_REGISTRY_PUBLIC_URL=http://localhost:8085

# ── Debezium (Kafka Connect) ───────────────────────────────────
DEBEZIUM_PORT=8083
DEBEZIUM_PASSWORD=local_debezium_password

# ── PostgreSQL (공통 계정 - 로컬 개발용) ──────────────────────
# 실 서비스별로 분리하는 것이 권장되나 로컬에서는 공통 계정 사용
POSTGRES_HOST=localhost
POSTGRES_USER=appuser
POSTGRES_PASSWORD=local_password

POSTGRES_AUCTION_PORT=5432
POSTGRES_BID_PORT=5433
POSTGRES_USER_PORT=5434

POSTGRES_USER_DB_NAME=user_db
POSTGRES_AUCTION_DB_NAME=auction_db
POSTGRES_BID_DB_NAME=bid_db

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=local_redis_password

# ── Kafka UI ───────────────────────────────────────────────────
KAFKA_UI_PORT=9000

# ── auction-streams ────────────────────────────────────────────
# HTTP(Interactive Query 등). 8085(Schema Registry 호스트 포트)와 혼동하지 말 것. docs/architecture.md 서비스 표 참고.
AUCTION_STREAMS_PORT=8086
# 멀티 인스턴스 IQ 시 반드시 Pod별 host:port를 지정한다.
# local 프로필 단일 실행만 생략 가능(기본 localhost:${AUCTION_STREAMS_PORT}).
# local 외 프로필에서는 localhost 금지.
# KAFKA_STREAMS_APPLICATION_SERVER=localhost:8086
# Punctuator 주기(초). Spring 표준: AUCTION_STREAMS_PUNCTUATOR_INTERVAL_SECONDS — 구 호환: PUNCTUATOR_INTERVAL_SECONDS
AUCTION_STREAMS_PUNCTUATOR_INTERVAL_SECONDS=30
# Streams 스레드 연속 실패 허용. Spring 표준: AUCTION_STREAMS_MAX_FAILURES — 구 호환: STREAMS_MAX_FAILURES
AUCTION_STREAMS_MAX_FAILURES=5
# 멀티 인스턴스 IQ peer RestClient 타임아웃(ms). 기본 2000/3000 — auction-service·bid-service의 auction-streams 호출과 동일.
# AUCTION_STREAMS_IQ_PEER_CONNECT_TIMEOUT_MS=2000
# AUCTION_STREAMS_IQ_PEER_READ_TIMEOUT_MS=3000

# ── JWT (RSA 키 쌍) ────────────────────────────────────────────
# RSA 2048 키 쌍 생성 방법:
#   openssl genrsa -out private.pem 2048
#   openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in private.pem -out private_pkcs8.pem
#   openssl rsa -in private.pem -pubout -out public.pem
# Base64 인코딩 (헤더/푸터 제거):
#   cat private_pkcs8.pem | grep -v "\-\-\-" | tr -d '\n'  → JWT_PRIVATE_KEY
#   cat public.pem | grep -v "\-\-\-" | tr -d '\n'          → JWT_PUBLIC_KEY
JWT_PRIVATE_KEY="<Base64_PKCS8_RSA_PrivateKey>"
JWT_PUBLIC_KEY="<Base64_X509_RSA_PublicKey>"

# ── 내부 서비스 인증 ──────────────────────────────────────────
# Gateway → auction-service 요청 검증용 사전 공유 시크릿
# 생성 방법: openssl rand -hex 32
# Gateway와 auction-service 양쪽에 동일한 값을 주입해야 함
# 자세한 내용: docs/internal-service-auth.md
INTERNAL_REQUEST_SECRET="<openssl rand -hex 32 으로 생성한 값>"

# auction/bid-service OAuth2 Resource Server — user-service JWKS에서 JWT 서명 검증용 공개키 조회
JWK_SET_URI=http://user-service/.well-known/jwks.json

# ── API Gateway (bootRun 시 환경변수 주입용) ────────────────────
API_GATEWAY_PORT=8080
USER_SERVICE_URI=http://localhost:8083
AUCTION_SERVICE_URI=http://localhost:8081
BID_SERVICE_URI=http://localhost:8082
NOTIFICATION_SERVICE_URI=http://localhost:8084
# auction-service / bid-service → auction-streams Interactive Query (application.yml 의 AUCTION_STREAMS_BASE_URL)
AUCTION_STREAMS_BASE_URL=http://localhost:8086

# ── OpenAPI / Swagger (REST 서비스) ─────────────────────────────
# 운영 환경에서는 false 권장. user/auction/bid-service application.yml 에서 참조
SWAGGER_ENABLED=true

# ── 각 서비스 포트 (bootRun 시 server.port로 주입) ──────────────
USER_SERVICE_PORT=8083
AUCTION_SERVICE_PORT=8081
BID_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8084
